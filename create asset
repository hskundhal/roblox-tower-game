-- Noob-Builder Script
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local towerFolder = ReplicatedStorage:FindFirstChild("Towers") or Instance.new("Folder", ReplicatedStorage)
towerFolder.Name = "Towers"

local model = Instance.new("Model")
model.Name = "BasicTower"
model.Parent = towerFolder

local function createPart(name, size, cframe, color, material)
    local p = Instance.new("Part")
    p.Name = name
    p.Size = size
    p.CFrame = cframe
    p.Color = color
    p.Material = material or Enum.Material.Plastic
    p.Anchored = true
    p.CanCollide = true
    p.Parent = model
    return p
end

